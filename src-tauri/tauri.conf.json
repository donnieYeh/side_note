{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Side Note",
  "version": "0.3.1",
  "identifier": "com.local.sidenote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Side Note",
        "width": 980,
        "height": 640,
        "minWidth": 760,
        "minHeight": 540,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Dockable markdown sticky notes",
    "icon": ["icons/icon.ico"]
  }
}
